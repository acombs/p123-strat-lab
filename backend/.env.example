P123_API_ID=your_api_id_here
P123_API_KEY=your_api_key_here

# Comma-separated strategy IDs — ranking systems from these strategies
# appear in the ranking system autocomplete. Find IDs in the P123 URL
# when viewing a strategy: .../app/strategy/edit/XXXXXXX
P123_STRATEGY_IDS=1234567,7654321

ENV=development
