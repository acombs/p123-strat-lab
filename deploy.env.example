# Deployment target for ./deploy.sh — copy to deploy.env (gitignored) and fill in.

# Your GCP project id (required)
PROJECT=my-gcp-project

# Who may access the app through IAP (required), e.g. user:you@example.com
# or group:team@example.com
IAP_MEMBER=user:you@example.com

# Optional overrides
#SERVICE=p123-strategy-lab
#REGION=us-central1
#STATE_BUCKET=my-gcp-project-p123-state
